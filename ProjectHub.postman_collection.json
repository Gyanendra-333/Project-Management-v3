{
  "info": {
    "name": "ProjectHub API",
    "description": "Advanced MERN Project Management System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": ["const r = pm.response.json();", "if(r.token) pm.collectionVariables.set('token', r.token);"] }
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/projects?page=1&limit=10&status=Pending", "query": [
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "10" },
              { "key": "status", "value": "Pending" },
              { "key": "search", "value": "", "disabled": true }
            ]},
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/projects/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Project (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/projects",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "New Website Redesign", "type": "text" },
                { "key": "description", "value": "Complete overhaul of the company website", "type": "text" },
                { "key": "startDate", "value": "2025-01-01", "type": "text" },
                { "key": "endDate", "value": "2025-03-31", "type": "text" },
                { "key": "status", "value": "Pending", "type": "text" },
                { "key": "assignedUsers", "value": "[]", "type": "text" },
                { "key": "attachments", "type": "file", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Update Project (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/projects/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Updated Title", "type": "text" },
                { "key": "status", "value": "In-Progress", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Update Project Status",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/projects/:id/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"In-Progress\"\n}" }
          }
        },
        {
          "name": "Delete Project (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/projects/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/users?page=1&limit=10", "query": [
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "10" },
              { "key": "search", "value": "", "disabled": true },
              { "key": "role", "value": "", "disabled": true }
            ]},
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create User (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"user\"\n}" }
          }
        },
        {
          "name": "Update User (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/users/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Updated\",\n  \"role\": \"admin\"\n}" }
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/users/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Own Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/users/profile",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My Updated Name\",\n  \"email\": \"updated@example.com\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats (Admin)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Activity",
      "item": [
        {
          "name": "Get Activity Logs (Admin)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/activity?page=1&limit=20", "query": [
              { "key": "page", "value": "1" },
              { "key": "limit", "value": "20" },
              { "key": "entity", "value": "", "disabled": true }
            ]},
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
